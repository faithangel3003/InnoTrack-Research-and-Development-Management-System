@inherits LayoutComponentBase
@inject NavigationManager Navigation
@using System.Globalization

@if (IsPublicPage)
{
    <main class="public-main">
        <article class="content p-0">
            @Body
        </article>
    </main>
}
else
{
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <div class="top-row px-4">
                <h2 class="page-title">@GetPageTitle()</h2>
                <div class="top-row-right">
                    <span class="header-date">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
                    <div class="header-icons">
                        <button class="icon-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg></button>
                        <div class="user-pill">
                            <div class="user-avatar">MT</div>
                            <div class="user-info">
                                <div class="user-name">Faith Angel Rasonable</div>
                                <div class="user-role">Super Administrator</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <article class="content px-4 py-4">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool IsPublicPage
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(path) || path.StartsWith("login", StringComparison.OrdinalIgnoreCase);
        }
    }

    private string GetPageTitle()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).ToLower();
        
        if (path.StartsWith("companies"))
            return "Companies";
        if (path.StartsWith("subscriptions"))
            return "Subscriptions";
        if (path.StartsWith("payments"))
            return "Payments";
        if (path.StartsWith("reports"))
            return "Reports";
        if (path.StartsWith("settings"))
            return "Settings";
        
        return "Dashboard";
    }
}
