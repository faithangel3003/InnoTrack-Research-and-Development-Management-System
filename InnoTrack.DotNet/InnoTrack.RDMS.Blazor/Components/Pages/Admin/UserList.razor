@page "/admin/users"
@attribute [Authorize(Roles = "Super Admin,System Admin")]
@inject InnoTrackApiClient ApiClient
@inject AuthState AuthState
@inject NavigationManager Navigation

<PageTitle>User Management</PageTitle>

<h1>User & Role Management</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p style="color:crimson">@errorMessage</p>
}

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end justify-content-between">
        <div style="min-width: 280px; flex: 1 1 320px;">
            <label class="form-label">Search users</label>
            <input class="form-control" placeholder="Search by name, email, role, or organization" @bind="searchText" @bind:event="oninput" />
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="GoToCreate">Create User</button>
            <button class="btn btn-outline-secondary" @onclick="LoadAsync">Refresh</button>
        </div>
    </div>
</div>

@if (users is null)
{
    <p><em>Loading users...</em></p>
}
else
{
    @if (pagedUsers.Count == 0)
    {
        <div class="alert alert-info">No users matched the current filter.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Organization</th>
                        <th>Status</th>
                        <th>Updated (UTC)</th>
                        <th>Change Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in pagedUsers)
                    {
                        <tr>
                            <td>@($"{user.FirstName} {user.LastName}")</td>
                            <td>@user.Email</td>
                            <td>@user.RoleName</td>
                            <td>@(string.IsNullOrWhiteSpace(user.OrganizationName) ? "Unassigned" : user.OrganizationName)</td>
                            <td>@(user.IsActive ? "Active" : "Inactive")</td>
                            <td>@user.UpdatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (canManageSensitiveActions)
                                {
                                    <div class="d-flex gap-2" style="min-width: 220px;">
                                        <select class="form-select form-select-sm" value="@GetSelectedRoleId(user)" @onchange="(e => SelectRole(user.Id, e.Value?.ToString()))">
                                            @foreach (var role in roles)
                                            {
                                                <option value="@role.Id">@role.RoleName</option>
                                            }
                                        </select>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                disabled="@(GetSelectedRoleId(user) == user.RoleId)"
                                                @onclick="(() => ChangeRoleAsync(user))">
                                            Apply
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">Super Admin only</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex; gap:8px;">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="(() => Edit(user.Id))">Edit</button>
                                    @if (canManageSensitiveActions)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" disabled="@(!user.IsActive)" @onclick="(() => DeactivateAsync(user.Id))">Deactivate</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3">
            <div class="text-muted small">Showing @pageStart to @pageEnd of @filteredUsers.Count users</div>
            <div class="d-flex gap-2 align-items-center">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                <span class="small">Page @currentPage of @totalPages</span>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Next</button>
            </div>
        </div>
    }
}

@code {
    private List<UserViewModel>? users;
    private List<RoleViewModel> roles = [];
    private readonly Dictionary<Guid, int> selectedRoles = [];
    private string? errorMessage;
    private string searchText = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 8;
    private bool canManageSensitiveActions;

    private List<UserViewModel> filteredUsers => (users ?? [])
        .Where(user => string.IsNullOrWhiteSpace(searchText)
            || $"{user.FirstName} {user.LastName}".Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || user.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || user.RoleName.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || (user.OrganizationName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(user => user.LastName)
        .ThenBy(user => user.FirstName)
        .ToList();

    private List<UserViewModel> pagedUsers => filteredUsers
        .Skip((currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int totalPages => Math.Max(1, (int)Math.Ceiling(filteredUsers.Count / (double)PageSize));
    private int pageStart => filteredUsers.Count == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int pageEnd => Math.Min(currentPage * PageSize, filteredUsers.Count);

    protected override async Task OnInitializedAsync()
    {
        canManageSensitiveActions = AuthState.HasRole("Super Admin");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            errorMessage = null;
            roles = await ApiClient.GetRolesAsync();
            users = await ApiClient.GetUsersAsync();
            selectedRoles.Clear();

            foreach (var user in users)
            {
                selectedRoles[user.Id] = user.RoleId;
            }

            currentPage = 1;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/admin/users/create");
    }

    private void Edit(Guid userId)
    {
        Navigation.NavigateTo($"/admin/users/edit/{userId}");
    }

    private int GetSelectedRoleId(UserViewModel user)
    {
        return selectedRoles.TryGetValue(user.Id, out var roleId) ? roleId : user.RoleId;
    }

    private void SelectRole(Guid userId, string? value)
    {
        if (int.TryParse(value, out var roleId))
        {
            selectedRoles[userId] = roleId;
        }
    }

    private async Task ChangeRoleAsync(UserViewModel user)
    {
        try
        {
            errorMessage = null;
            await ApiClient.ChangeUserRoleAsync(user.Id, GetSelectedRoleId(user));
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task DeactivateAsync(Guid userId)
    {
        try
        {
            await ApiClient.DeactivateUserAsync(userId);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
        }
    }
}
