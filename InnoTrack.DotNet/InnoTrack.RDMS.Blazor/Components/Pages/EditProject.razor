@page "/projects/edit/{ProjectId:guid}"
@attribute [Authorize(Roles = "Project Manager")]
@inject ProjectApiService ProjectApiService
@inject NavigationManager Navigation

<PageTitle>Edit Project</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <button type="button" class="btn btn-link ps-0" @onclick="Cancel">&larr; Back</button>
        <h1 class="h3 mb-1">Edit Project</h1>
        <p class="text-muted mb-0">Update project details and status</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <p><em>Loading project...</em></p>
}
else if (model is null)
{
    <div class="alert alert-warning">Project not found.</div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="model" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />

                        <h6 class="mb-3">Project Information</h6>

                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <InputText class="form-control" @bind-Value="model.Title" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" rows="4" @bind-Value="model.Description" />
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-select" @bind-Value="model.Priority">
                                    <option>Low</option>
                                    <option>Medium</option>
                                    <option>High</option>
                                    <option>Critical</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Start Date</label>
                                <InputDate class="form-control" @bind-Value="model.StartDate" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">End Date</label>
                                <InputDate class="form-control" @bind-Value="model.EndDate" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Organization Id</label>
                            <InputText class="form-control" @bind-Value="organizationIdText" />
                        </div>

                        <hr />
                        <h6 class="mb-3">Project Status</h6>
                        <div class="mb-2">
                            <span class="text-muted">Current:</span>
                            <StatusBadge Status="@status" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Change Status</label>
                            <InputSelect class="form-select" @bind-Value="status">
                                <option>Draft</option>
                                <option>Active</option>
                                <option>OnHold</option>
                                <option>Completed</option>
                                <option>Cancelled</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Remarks</label>
                            <InputTextArea class="form-control" rows="2" @bind-Value="statusRemarks" />
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">Save</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="Cancel">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-danger">
                <div class="card-body">
                    <h6 class="text-danger">Danger Zone</h6>
                    <p class="small text-muted">Delete Project. This action is irreversible and removes related tasks and milestones.</p>
                    <button class="btn btn-outline-danger" disabled="@(!canDeleteCurrentStatus)" @onclick="AskDelete">Delete Project</button>
                    @if (!canDeleteCurrentStatus)
                    {
                        <p class="small text-warning mt-2 mb-0">Cannot delete an Active project. Change to Cancelled first.</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<ConfirmModal IsOpen="isDeleteModalOpen"
              Title="Delete Project"
              Message="This will permanently delete the project. Continue?"
              ConfirmText="Delete"
              IsDanger="true"
              OnConfirm="DeleteProjectAsync"
              OnCancel="CloseDeleteModal" />

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private UpdateProjectRequestModel? model;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string organizationIdText = string.Empty;
    private string status = "Draft";
    private string originalStatus = "Draft";
    private string? statusRemarks;
    private bool isDeleteModalOpen;

    private bool canDeleteCurrentStatus => status != "Active";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;

        try
        {
            var project = await ProjectApiService.GetProjectByIdAsync(ProjectId);
            if (project is null)
            {
                model = null;
                return;
            }

            model = new UpdateProjectRequestModel
            {
                Title = project.Title,
                Description = project.Description,
                Priority = project.Priority,
                StartDate = project.StartDate,
                EndDate = project.EndDate,
                OrganizationId = project.OrganizationId
            };

            organizationIdText = project.OrganizationId.ToString();
            status = project.Status;
            originalStatus = project.Status;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (model is null)
        {
            return;
        }

        errorMessage = null;

        if (!Guid.TryParse(organizationIdText, out var orgId))
        {
            errorMessage = "Please provide a valid Organization Id (GUID).";
            return;
        }

        if (model.EndDate < DateTime.Today)
        {
            errorMessage = "End Date cannot be set before today.";
            return;
        }

        if (model.EndDate <= model.StartDate)
        {
            errorMessage = "End Date must be after Start Date.";
            return;
        }

        if (!string.Equals(status, originalStatus, StringComparison.Ordinal) && string.IsNullOrWhiteSpace(statusRemarks))
        {
            errorMessage = "Remarks are required when changing status.";
            return;
        }

        isSubmitting = true;

        try
        {
            model.OrganizationId = orgId;
            await ProjectApiService.UpdateProjectAsync(ProjectId, model);

            await ProjectApiService.ChangeProjectStatusAsync(ProjectId, new ChangeProjectStatusRequestModel
            {
                Status = status,
                Remarks = string.IsNullOrWhiteSpace(statusRemarks) ? "Updated from UI" : statusRemarks
            });

            Navigation.NavigateTo($"/projects/{ProjectId}");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void AskDelete()
    {
        if (!canDeleteCurrentStatus)
        {
            return;
        }

        isDeleteModalOpen = true;
    }

    private Task CloseDeleteModal()
    {
        isDeleteModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task DeleteProjectAsync()
    {
        try
        {
            await ProjectApiService.DeleteProjectAsync(ProjectId);
            Navigation.NavigateTo("/projects");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isDeleteModalOpen = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo($"/projects/{ProjectId}");
}
