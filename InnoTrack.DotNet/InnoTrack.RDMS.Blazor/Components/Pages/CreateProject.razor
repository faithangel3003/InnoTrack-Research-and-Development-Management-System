@page "/projects/create"
@attribute [Authorize(Roles = "Project Manager")]
@inject ProjectApiService ProjectApiService
@inject NavigationManager Navigation

<PageTitle>Create Project</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <button type="button" class="btn btn-link ps-0" @onclick="Cancel">&larr; Back</button>
        <h1 class="h3 mb-1">Create New Project</h1>
        <p class="text-muted mb-0">Start a new research project</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <EditForm Model="model" OnValidSubmit="CreateAsync">
                    <DataAnnotationsValidator />

                    <h6 class="mb-3">Project Information</h6>

                    <div class="mb-3">
                        <label class="form-label">Project Title *</label>
                        <InputText class="form-control" @bind-Value="model.Title" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" rows="4" @bind-Value="model.Description" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Priority *</label>
                        <InputSelect class="form-select" @bind-Value="model.Priority">
                            <option>Low</option>
                            <option>Medium</option>
                            <option>High</option>
                            <option>Critical</option>
                        </InputSelect>
                    </div>

                    <h6 class="mb-3 mt-4">Project Timeline</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Start Date *</label>
                            <InputDate class="form-control" @bind-Value="model.StartDate" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">End Date *</label>
                            <InputDate class="form-control" @bind-Value="model.EndDate" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Organization Id *</label>
                        <InputText class="form-control" @bind-Value="organizationIdText" />
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" type="button" @onclick="Cancel">Cancel</button>
                        <button class="btn btn-primary" type="submit" disabled="@isSubmitting">Create Project &rarr;</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card bg-light border-0">
            <div class="card-body">
                <h6 class="mb-3">Tips</h6>
                <p class="small mb-2">Good project titles are specific and descriptive.</p>
                <p class="small mb-2">Set realistic deadlines to keep your team motivated.</p>
                <p class="small mb-0">Break down work into clear tasks after creating the project.</p>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly CreateProjectRequestModel model = new()
    {
        StartDate = DateTime.Today,
        EndDate = DateTime.Today.AddDays(30)
    };

    private bool isSubmitting;
    private string? errorMessage;
    private string organizationIdText = string.Empty;

    private async Task CreateAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Title) || model.Title.Trim().Length < 3 || model.Title.Trim().Length > 150)
        {
            errorMessage = "Title must be between 3 and 150 characters.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(model.Description) && model.Description.Length > 5000)
        {
            errorMessage = "Description must not exceed 5000 characters.";
            return;
        }

        if (!Guid.TryParse(organizationIdText, out var orgId))
        {
            errorMessage = "Please provide a valid Organization Id (GUID).";
            return;
        }

        if (model.StartDate.Date < DateTime.Today)
        {
            errorMessage = "Start Date must not be in the past.";
            return;
        }

        if (model.EndDate <= model.StartDate)
        {
            errorMessage = "End Date must be after Start Date.";
            return;
        }

        isSubmitting = true;

        try
        {
            model.OrganizationId = orgId;
            model.Title = model.Title.Trim();
            var created = await ProjectApiService.CreateProjectAsync(model);
            Navigation.NavigateTo($"/projects/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/projects");
}
