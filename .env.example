# Frontend
VITE_API_BASE_URL=http://localhost:5110/api
VITE_ACTOR_USER_ID=
VITE_RECAPTCHA_SITE_KEY=replace-with-recaptcha-v2-site-key

# Optional Supabase fallback (only needed if you still use Supabase mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API
API_PORT=5110
CLIENT_URL=http://localhost:5173
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
PAYMONGO_BASE_URL=https://api.paymongo.com/v1/
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=

# JWT
JWT_ISSUER=InnoTrack.Local
JWT_AUDIENCE=InnoTrack.Client
JWT_SIGNING_KEY=replace-with-a-long-random-secret
JWT_EXPIRY_MINUTES=120

# AES-256 values must be Base64 encoded.
ENCRYPTION_KEY=replace-with-32-byte-base64-key
ENCRYPTION_IV=replace-with-16-byte-base64-iv

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=innotrack
DB_SSL_MODE=None
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# Optional SMTP settings for OTP/password-recovery email testing.
# Point these at a sandbox such as Mailpit/MailHog or a real test SMTP server.
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@innotrack.local
SMTP_FROM_NAME=InnoTrack Local
SMTP_ENABLE_SSL=false

RECAPTCHA_SECRET_KEY=replace-with-recaptcha-v2-secret-key
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
