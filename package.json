{
  "name": "innotrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "clean:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-dev.ps1",
    "dev:mail": "node -e \"console.error('Local SMTP inbox capture is no longer bundled. Point SMTP_HOST/SMTP_PORT at an external sandbox such as Mailpit or MailHog when you need to inspect OTP emails.'); process.exit(1)\"",
    "dev:web": "vite --host localhost --port 5174 --strictPort",
    "dev:api": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-api-dev.ps1",
    "dev:full": "npm run clean:dev && concurrently -k -n API,WEB -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:api": "dotnet build InnoTrack.DotNet/InnoTrack.RDMS.Api/InnoTrack.RDMS.Api.csproj -p:UseAppHost=false -o InnoTrack.DotNet/build-validation/validate-api",
    "lint": "eslint .",
    "validate": "npm run lint && npm run build:web && npm run build:api",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/html2pdf.js": "^0.10.0",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
